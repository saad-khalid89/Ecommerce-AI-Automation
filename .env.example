# Frontend Environment Variables

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Session Secret (generate a random 32+ character string)
# Use: openssl rand -base64 32
SESSION_SECRET=generate-a-secure-random-key-minimum-32-characters

# Optional: Default Shopify credentials for development
# NEXT_PUBLIC_DEFAULT_SHOP_DOMAIN=your-store.myshopify.com
# NEXT_PUBLIC_DEFAULT_ACCESS_TOKEN=shpat_xxxxx

# Optional: Analytics
# NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# Optional: Feature Flags
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_AI_FEATURES=true